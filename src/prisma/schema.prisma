generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model campus {
  id      String    @id @default(uuid()) @db.VarChar(36)
  name    String    @db.VarChar(255)
  canteen canteen[]
  user    user[]
}

model canteen {
  id             String           @id @default(uuid()) @db.VarChar(36)
  campus_id      String?          @db.VarChar(36)
  name           String           @db.VarChar(255)
  address        String?          @db.Text
  image          String           @db.VarChar(255)
  campus         campus?          @relation(fields: [campus_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_canteen_campus")
  canteen_review canteen_review[]
  daily_report   daily_report[]
  inventory      inventory[]
  order          order[]
  shift          shift[]
  user           user[]

  @@index([campus_id], map: "fk_canteen_campus")
}

model user {
  id                         String                   @id @default(uuid()) @db.VarChar(36)
  campus_id                  String?                  @db.VarChar(36)
  canteen_id                 String?                  @db.VarChar(36)
  name                       String                   @db.VarChar(255)
  email                      String                   @unique(map: "email") @db.VarChar(255)
  password                   String                   @db.VarChar(255)
  role                       user_role?               @default(STUDENT)
  birthday                   DateTime?                @db.Date
  status                     user_status?             @default(ACTIVE)
  email_parents              String?                  @db.VarChar(255)
  created_at                 DateTime?                @default(now()) @db.Timestamp(0)
  updated_at                 DateTime?                @default(now()) @db.Timestamp(0)
  bonus_discipline           bonus_discipline[]
  canteen_review             canteen_review[]
  canteen_review_comment     canteen_review_comment[]
  inventory_transaction      inventory_transaction[]
  order_order_staff_idTouser order[]                  @relation("order_staff_idTouser")
  order_order_user_idTouser  order[]                  @relation("order_user_idTouser")
  payroll                    payroll[]
  product_review             product_review[]
  product_review_comment     product_review_comment[]
  staff_contract             staff_contract[]
  staff_schedule             staff_schedule[]
  campus                     campus?                  @relation(fields: [campus_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_campus")
  canteen                    canteen?                 @relation(fields: [canteen_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_canteen")
  user_subscription          user_subscription[]
  voucher_user               voucher_user[]
  wallet                     wallet?

  @@index([campus_id], map: "fk_user_campus")
  @@index([canteen_id], map: "fk_user_canteen")
}

model wallet {
  id                 String               @id @default(uuid()) @db.VarChar(36)
  user_id            String               @unique(map: "user_id") @db.VarChar(36)
  balance            Decimal?             @default(0.00) @db.Decimal(15, 2)
  level              Int?                 @default(1)
  total_spending     Decimal?             @default(0.00) @db.Decimal(15, 2)
  updated_at         DateTime?            @default(now()) @db.Timestamp(0)
  user               user                 @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wallet_user")
  wallet_transaction wallet_transaction[]
}

model product {
  id              String           @id @default(uuid()) @db.VarChar(36)
  product_name    String           @db.VarChar(255)
  category        product_category
  price           Decimal          @default(0.00) @db.Decimal(15, 2)
  unit            String           @default("kg") @db.VarChar(20)
  is_selling      Boolean          @default(true)
  is_available    Boolean          @default(true)
  is_subscription Boolean          @default(true)
  protein         Decimal          @default(0.00) @db.Decimal(10, 2)
  fat             Decimal          @default(0.00) @db.Decimal(10, 2)
  calo            Decimal          @default(0.00) @db.Decimal(10, 2)
  inventories            inventory[]
  inventory_transactions inventory_transaction[]
  order_items            order_item[]
  product_reviews        product_review[]
  recipes                product_recipe[] @relation("product_recipe_product_idToproduct")
  used_in_recipes        product_recipe[] @relation("product_recipe_material_idToproduct")
}

model product_recipe {
  id                                          String  @id @default(uuid()) @db.VarChar(36)
  product_id                                  String  @db.VarChar(36)
  material_id                                 String  @db.VarChar(36)
  quantity                                    Decimal @db.Decimal(15, 3)
  unit                                        String? @default("kg") @db.VarChar(20)
  material    product @relation("product_recipe_material_idToproduct", fields: [material_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_recipe_material")
  final_product product @relation("product_recipe_product_idToproduct", fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_recipe_product")
  @@index([material_id], map: "fk_recipe_material")
  @@index([product_id], map: "fk_recipe_product")
}

model inventory {
  id                    String                  @id @default(uuid()) @db.VarChar(36)
  product_id            String?                 @db.VarChar(36)
  canteen_id            String?                 @db.VarChar(36)
  quantity              Decimal?                @default(0.000) @db.Decimal(15, 3)
  unit                  String?                 @default("kg") @db.VarChar(20)
  min_stock             Decimal?                @default(0.000) @db.Decimal(15, 3)
  canteen               canteen?                @relation(fields: [canteen_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inventory_canteen")
  product               product?                @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inventory_product")
  inventory_transaction inventory_transaction[]

  @@index([canteen_id], map: "fk_inventory_canteen")
  @@index([product_id], map: "fk_inventory_product")
}

model order {
  id                        String                  @id @default(uuid()) @db.VarChar(36)
  user_id                   String                  @db.VarChar(36)
  canteen_id                String                  @db.VarChar(36)
  user_sub_id               String?                 @db.VarChar(36)
  staff_id                  String?                 @db.VarChar(36)
  voucher_id                String?                 @db.VarChar(36)
  payment_method            order_payment_method?   @default(WALLET)
  total_price               Decimal                 @db.Decimal(15, 2)
  discount                  Decimal?                @default(0.00) @db.Decimal(15, 2)
  status                    order_status?           @default(PENDING)
  created_at                DateTime?               @default(now()) @db.Timestamp(0)
  inventory_transaction     inventory_transaction[]
  canteen                   canteen                 @relation(fields: [canteen_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_canteen")
  user_order_staff_idTouser user?                   @relation("order_staff_idTouser", fields: [staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_staff")
  user_subscription         user_subscription?      @relation(fields: [user_sub_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_sub")
  user_order_user_idTouser  user                    @relation("order_user_idTouser", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_user")
  voucher                   voucher?                @relation(fields: [voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_voucher")
  order_item                order_item[]
  product_review            product_review[]
  wallet_transaction        wallet_transaction[]

  @@index([canteen_id], map: "fk_order_canteen")
  @@index([staff_id], map: "fk_order_staff")
  @@index([user_sub_id], map: "fk_order_sub")
  @@index([user_id], map: "fk_order_user")
  @@index([voucher_id], map: "fk_order_voucher")
}

model order_item {
  id                String  @id @default(uuid()) @db.VarChar(36)
  order_id          String  @db.VarChar(36)
  product_id        String  @db.VarChar(36)
  quantity          Decimal @db.Decimal(15, 3)
  price_at_purchase Decimal @db.Decimal(15, 2)
  order             order   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_item_order")
  product           product @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_item_product")

  @@index([order_id], map: "fk_item_order")
  @@index([product_id], map: "fk_item_product")
}

model inventory_transaction {
  id           String                     @id @default(uuid()) @db.VarChar(36)
  inventory_id String?                    @db.VarChar(36)
  product_id   String?                    @db.VarChar(36)
  staff_id     String?                    @db.VarChar(36)
  order_id     String?                    @db.VarChar(36)
  quantity     Decimal                    @db.Decimal(15, 3)
  unit         String?                    @default("kg") @db.VarChar(20)
  type         inventory_transaction_type
  cost_price   Decimal?                   @default(0.00) @db.Decimal(15, 2)
  description  String?                    @db.Text
  created_at   DateTime?                  @default(now()) @db.Timestamp(0)
  inventory    inventory?                 @relation(fields: [inventory_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_itrans_inv")
  order        order?                     @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_itrans_order")
  product      product?                   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_itrans_prod")
  user         user?                      @relation(fields: [staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_itrans_staff")

  @@index([inventory_id], map: "fk_itrans_inv")
  @@index([order_id], map: "fk_itrans_order")
  @@index([product_id], map: "fk_itrans_prod")
  @@index([staff_id], map: "fk_itrans_staff")
}

model wallet_transaction {
  id          String                  @id @default(uuid()) @db.VarChar(36)
  wallet_id   String                  @db.VarChar(36)
  order_id    String?                 @db.VarChar(36)
  amount      Decimal                 @db.Decimal(15, 2)
  type        wallet_transaction_type
  description String?                 @db.Text
  created_at  DateTime?               @default(now()) @db.Timestamp(0)
  order       order?                  @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wtrans_order")
  wallet      wallet                  @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wtrans_wallet")

  @@index([order_id], map: "fk_wtrans_order")
  @@index([wallet_id], map: "fk_wtrans_wallet")
}

model voucher {
  id              String                @id @default(uuid()) @db.VarChar(36)
  code            String                @unique(map: "code") @db.VarChar(50)
  discount_value  Decimal               @db.Decimal(15, 2)
  discount_type   voucher_discount_type
  min_order_value Decimal?              @default(0.00) @db.Decimal(15, 2)
  max_discount    Decimal?              @db.Decimal(15, 2)
  start_date      DateTime              @db.DateTime(0)
  end_date        DateTime              @db.DateTime(0)
  usage_limit     Int?                  @default(1)
  is_active       Boolean?              @default(true)
  created_at      DateTime?             @default(now()) @db.Timestamp(0)
  order           order[]
  voucher_user    voucher_user[]
}

model voucher_user {
  id         String               @id @default(uuid()) @db.VarChar(36)
  user_id    String               @db.VarChar(36)
  voucher_id String               @db.VarChar(36)
  status     voucher_user_status? @default(AVAILABLE)
  used_at    DateTime?            @db.Timestamp(0)
  user       user                 @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vuser_user")
  voucher    voucher              @relation(fields: [voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vuser_voucher")

  @@index([user_id], map: "fk_vuser_user")
  @@index([voucher_id], map: "fk_vuser_voucher")
}

model subscription_plan {
  id                 String                                @id @default(uuid()) @db.VarChar(36)
  name               String                                @db.VarChar(100)
  price              Decimal                               @db.Decimal(15, 2)
  total_meals        Int
  duration_days      Int
  subscription_scope subscription_plan_subscription_scope? @default(ALL)
  is_active          Boolean?                              @default(true)
  user_subscription  user_subscription[]
}

model user_subscription {
  id                String                    @id @default(uuid()) @db.VarChar(36)
  user_id           String                    @db.VarChar(36)
  plan_id           String                    @db.VarChar(36)
  remaining_meals   Int
  status            user_subscription_status? @default(ACTIVE)
  start_date        DateTime                  @db.DateTime(0)
  end_date          DateTime                  @db.DateTime(0)
  order             order[]
  subscription_plan subscription_plan         @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usub_plan")
  user              user                      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usub_user")

  @@index([plan_id], map: "fk_usub_plan")
  @@index([user_id], map: "fk_usub_user")
}

model product_review {
  id                     String                   @id @default(uuid()) @db.VarChar(36)
  user_id                String                   @db.VarChar(36)
  order_id               String?                  @db.VarChar(36)
  product_id             String                   @db.VarChar(36)
  comment                String?                  @db.Text
  image                  String?                  @db.VarChar(255)
  rating                 Int                      @db.TinyInt
  is_anonymous           Boolean?                 @default(false)
  is_hidden              Boolean?                 @default(false)
  created_at             DateTime?                @default(now()) @db.Timestamp(0)
  order                  order?                   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_preview_order")
  product                product                  @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_preview_prod")
  user                   user                     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_preview_user")
  product_review_comment product_review_comment[]

  @@index([order_id], map: "fk_preview_order")
  @@index([product_id], map: "fk_preview_prod")
  @@index([user_id], map: "fk_preview_user")
}

model product_review_comment {
  id             String         @id @default(uuid()) @db.VarChar(36)
  user_id        String         @db.VarChar(36)
  food_review_id String         @db.VarChar(36)
  description    String         @db.Text
  image          String?        @db.VarChar(255)
  is_anonymous   Boolean?       @default(false)
  is_hidden      Boolean?       @default(false)
  created_at     DateTime?      @default(now()) @db.Timestamp(0)
  product_review product_review @relation(fields: [food_review_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pcomment_review")
  user           user           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pcomment_user")

  @@index([food_review_id], map: "fk_pcomment_review")
  @@index([user_id], map: "fk_pcomment_user")
}

model canteen_review {
  id                     String                   @id @default(uuid()) @db.VarChar(36)
  user_id                String                   @db.VarChar(36)
  canteen_id             String                   @db.VarChar(36)
  category               canteen_review_category? @default(SERVICE)
  comment                String?                  @db.Text
  rating                 Int                      @db.TinyInt
  image                  String?                  @db.VarChar(255)
  is_anonymous           Boolean?                 @default(false)
  is_hidden              Boolean?                 @default(false)
  created_at             DateTime?                @default(now()) @db.Timestamp(0)
  canteen                canteen                  @relation(fields: [canteen_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_creview_canteen")
  user                   user                     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_creview_user")
  canteen_review_comment canteen_review_comment[]

  @@index([canteen_id], map: "fk_creview_canteen")
  @@index([user_id], map: "fk_creview_user")
}

model canteen_review_comment {
  id                String         @id @default(uuid()) @db.VarChar(36)
  user_id           String         @db.VarChar(36)
  canteen_review_id String         @db.VarChar(36)
  comment           String         @db.Text
  image             String?        @db.VarChar(255)
  is_anonymous      Boolean?       @default(false)
  is_hidden         Boolean?       @default(false)
  created_at        DateTime?      @default(now()) @db.Timestamp(0)
  canteen_review    canteen_review @relation(fields: [canteen_review_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ccomment_review")
  user              user           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ccomment_user")

  @@index([canteen_review_id], map: "fk_ccomment_review")
  @@index([user_id], map: "fk_ccomment_user")
}

model daily_report {
  id            String    @id @default(uuid()) @db.VarChar(36)
  canteen_id    String    @db.VarChar(36)
  total_revenue Decimal?  @default(0.00) @db.Decimal(15, 2)
  total_orders  Int?      @default(0)
  total_cost    Decimal?  @default(0.00) @db.Decimal(15, 2)
  net_profit    Decimal?  @default(0.00) @db.Decimal(15, 2)
  date_report   DateTime  @db.Date
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  created_by    String?   @db.VarChar(36)
  canteen       canteen   @relation(fields: [canteen_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_report_canteen")

  @@unique([canteen_id, date_report], map: "unique_canteen_date")
}

model shift {
  id             String           @id @default(uuid()) @db.VarChar(36)
  canteen_id     String           @db.VarChar(36)
  name           String           @db.VarChar(100)
  start_time     DateTime         @db.Time(0)
  end_time       DateTime         @db.Time(0)
  canteen        canteen          @relation(fields: [canteen_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_shift_canteen")
  staff_schedule staff_schedule[]

  @@index([canteen_id], map: "fk_shift_canteen")
}

model staff_schedule {
  id         String                 @id @default(uuid()) @db.VarChar(36)
  staff_id   String                 @db.VarChar(36)
  shift_id   String                 @db.VarChar(36)
  work_date  DateTime               @db.Date
  status     staff_schedule_status? @default(SCHEDULED)
  attendance attendance[]
  shift      shift                  @relation(fields: [shift_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_schedule_shift")
  user       user                   @relation(fields: [staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_schedule_staff")

  @@index([shift_id], map: "fk_schedule_shift")
  @@index([staff_id], map: "fk_schedule_staff")
}

model attendance {
  id                String         @id @default(uuid()) @db.VarChar(36)
  staff_schedule_id String         @db.VarChar(36)
  check_in          DateTime?      @db.Timestamp(0)
  check_out         DateTime?      @db.Timestamp(0)
  note              String?        @db.Text
  staff_schedule    staff_schedule @relation(fields: [staff_schedule_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_attendance_schedule")

  @@index([staff_schedule_id], map: "fk_attendance_schedule")
}

model staff_contract {
  id                   String                 @id @default(uuid()) @db.VarChar(36)
  user_id              String                 @db.VarChar(36)
  base_salary_per_hour Decimal                @db.Decimal(15, 2)
  allowance            Decimal?               @default(0.00) @db.Decimal(15, 2)
  start_date           DateTime               @db.Date
  end_date             DateTime?              @db.Date
  status               staff_contract_status? @default(ACTIVE)
  user                 user                   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_contract_user")

  @@index([user_id], map: "fk_contract_user")
}

model bonus_discipline {
  id         String                @id @default(uuid()) @db.VarChar(36)
  staff_id   String                @db.VarChar(36)
  type       bonus_discipline_type
  reason     String?               @db.Text
  amount     Decimal               @db.Decimal(15, 2)
  points     Int?                  @default(0)
  created_by String?               @db.VarChar(36)
  created_at DateTime?             @default(now()) @db.Timestamp(0)
  user       user                  @relation(fields: [staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bonus_staff")

  @@index([staff_id], map: "fk_bonus_staff")
}

model payroll {
  id               String          @id @default(uuid()) @db.VarChar(36)
  user_id          String          @db.VarChar(36)
  total_work_hours Decimal?        @default(0.00) @db.Decimal(10, 2)
  base_amount      Decimal         @db.Decimal(15, 2)
  total_discipline Decimal?        @default(0.00) @db.Decimal(15, 2)
  total_bonus      Decimal?        @default(0.00) @db.Decimal(15, 2)
  final_amount     Decimal         @db.Decimal(15, 2)
  month_year       String          @db.VarChar(7)
  status           payroll_status? @default(PENDING)
  user             user            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payroll_user")

  @@index([user_id], map: "fk_payroll_user")
}

enum bonus_discipline_type {
  BONUS
  DISCIPLINE
}

enum product_category {
  FOOD
  DRINK
  SNACK
  MATERIAL
}

enum voucher_discount_type {
  PERCENT
  FIXED
}

enum canteen_review_category {
  SERVICE
  CLEANLINESS
  SPACE
  OTHER
}

enum voucher_user_status {
  AVAILABLE
  USED
  EXPIRED
}

enum wallet_transaction_type {
  TOPUP
  PAYMENT
  REFUND
  WITHDRAW
}

enum staff_schedule_status {
  SCHEDULED
  COMPLETED
  ABSENT
  CANCELLED
}

enum user_subscription_status {
  ACTIVE
  EXPIRED
  USED_UP
}

enum subscription_plan_subscription_scope {
  ALL
  SINGLE
}

enum user_role {
  STUDENT
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum order_payment_method {
  WALLET
  CASH
  BANKING
  SUBSCRIPTION
}

enum staff_contract_status {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum inventory_transaction_type {
  IMPORT
  EXPORT
  WASTE
  ADJUST
}

enum user_status {
  ACTIVE
  INACTIVE
  BANNED
}

enum payroll_status {
  PENDING
  PAID
  CANCELLED
}

enum order_status {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}
